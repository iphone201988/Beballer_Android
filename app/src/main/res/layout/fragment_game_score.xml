<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <import type="android.view.View"/>

        <variable
            name="vm"
            type="com.beballer.beballer.ui.player.dash_board.find.game.game_score.GameScoreVm" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.player.dash_board.find.game.game_score.GameScoreFragment">

        <!-- Back Button -->
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/cancelImage"
            android:layout_width="@dimen/_30sdp"
            android:layout_height="@dimen/_30sdp"
            android:layout_marginStart="2dp"
            android:layout_marginTop="@dimen/_25sdp"
            android:padding="6dp"
            android:src="@drawable/back_button"
            android:onClick="@{vm::onClick}"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Title -->
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvTitle"
            style="@style/TextView.InterMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Matches"
            android:textSize="@dimen/_15ssp"
            app:layout_constraintBottom_toBottomOf="@id/cancelImage"
            app:layout_constraintStart_toEndOf="@id/cancelImage"
            app:layout_constraintTop_toTopOf="@id/cancelImage" />

        <!-- Date -->
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/date"
            style="@style/TextView.InterSemiBold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_15sdp"
            android:textSize="@dimen/_14ssp"
            android:text='@{vm.gameScoreDetails != null ? vm.gameScoreDetails.scoreBoardTitle : ""}'
            app:layout_constraintTop_toBottomOf="@id/cancelImage"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Game Status -->
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/gameStatus"
            style="@style/TextView.InterRegular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:textSize="@dimen/_13ssp"
            app:layout_constraintTop_toBottomOf="@id/date"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Score Board -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/consScoreBoard"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_110sdp"
            android:layout_marginTop="@dimen/_10sdp"
            android:background="@drawable/bg_game_score"
            android:layout_marginHorizontal="@dimen/_10sdp"
            app:layout_constraintTop_toBottomOf="@id/gameStatus"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Home -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvHome"
                style="@style/TextView.InterRegular"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="@dimen/_10ssp"
                android:layout_marginTop="@dimen/_10sdp"
                android:layout_marginStart="@dimen/_50sdp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <androidx.appcompat.widget.AppCompatEditText
                android:id="@+id/etHomeScore"
                style="@style/TextView.InterBold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/_18ssp"
                android:hint="0"
                android:textColorHint="@color/white"
                android:background="@null"
                android:layout_marginBottom="@dimen/_20sdp"
                android:textColor="@color/white"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@id/tvHome"
                app:layout_constraintEnd_toEndOf="@id/tvHome"/>

            <!-- Away -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvAway"
                style="@style/TextView.InterRegular"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Away"
                android:textSize="@dimen/_10ssp"
                android:layout_marginEnd="@dimen/_50sdp"
                app:layout_constraintTop_toTopOf="@id/tvHome"
                app:layout_constraintEnd_toEndOf="parent"/>

            <androidx.appcompat.widget.AppCompatEditText
                android:id="@+id/etAwayScore"
                style="@style/TextView.InterBold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/_18ssp"
                android:hint="0"
                android:textColorHint="@color/white"
                android:background="@null"
                android:layout_marginBottom="@dimen/_20sdp"
                android:textColor="@color/white"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@id/tvAway"
                app:layout_constraintEnd_toEndOf="@id/tvAway"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Buttons -->
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/btnPurposeThisScore"
            style="@style/GreenButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_45sdp"
            android:layout_marginHorizontal="@dimen/_13sdp"
            android:layout_marginBottom="@dimen/_10sdp"
            android:text="Purpose This Score"
            android:onClick="@{vm::onClick}"
            app:layout_constraintBottom_toTopOf="@id/btnConfirmThisScore"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/btnConfirmThisScore"
            style="@style/GreenButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_45sdp"
            android:layout_marginHorizontal="@dimen/_13sdp"
            android:layout_marginBottom="@dimen/_10sdp"
            android:text="Confirm This Score"
            android:onClick="@{vm::onClick}"
            app:layout_constraintBottom_toTopOf="@id/btnPurposeAnotherScore"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/btnPurposeAnotherScore"
            style="@style/GreenButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_45sdp"
            android:layout_marginHorizontal="@dimen/_13sdp"
            android:layout_marginBottom="@dimen/_10sdp"
            android:text="Purpose Another Score"
            android:onClick="@{vm::onClick}"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>