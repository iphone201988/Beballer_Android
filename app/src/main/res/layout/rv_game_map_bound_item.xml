<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <import type="android.view.View" />

        <variable
            name="bean"
            type="com.beballer.beballer.data.model.GameData" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clGameType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">


        <androidx.cardview.widget.CardView
            android:id="@+id/clMain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_10sdp"
            android:layout_marginVertical="@dimen/_10sdp"
            android:foreground="?android:attr/selectableItemBackground"
            app:cardCornerRadius="@dimen/_8sdp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:animateLayoutChanges="true">


                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/court_image"
                    setImageCourtUrl="@{bean.field.photos}"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@color/grey"
                    android:padding="@dimen/_4sdp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/iv_event"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintWidth_percent="0.36"
                    app:shapeAppearance="@style/ShapeAppearanceOverlay.App.CornerSize8Percent" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvGameDate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/_2sdp"
                    android:layout_marginTop="8dp"
                    android:ellipsize="end"
                    android:fontFamily="@font/inter_bold"
                    android:includeFontPadding="false"
                    android:maxLines="2"
                    android:text=""
                    android:textColor="@color/black_000000"
                    android:textSize="@dimen/_10ssp"
                    app:formattedDate="@{bean.date}"
                    app:layout_constraintEnd_toStartOf="@id/tvGameTime"
                    app:layout_constraintStart_toEndOf="@+id/court_image"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvGameTime"
                    formattedTime="@{bean.date}"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/_13sdp"
                    android:layout_marginTop="8dp"
                    android:ellipsize="end"
                    android:fontFamily="@font/inter_bold"
                    android:includeFontPadding="false"
                    android:maxLines="2"
                    android:textColor="@color/black_000000"
                    android:textSize="@dimen/_10ssp"
                    app:layout_constraintBottom_toBottomOf="@+id/tvGameDate"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />


                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvGameCity"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_3sdp"
                    android:layout_marginEnd="@dimen/_8sdp"
                    android:ellipsize="end"
                    android:fontFamily="@font/inter_bold"
                    android:includeFontPadding="false"
                    android:maxLines="2"
                    android:text="@{bean.field.address}"
                    android:textColor="@color/beballer_grey"
                    android:textSize="@dimen/_10ssp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@+id/tvGameDate"
                    app:layout_constraintTop_toBottomOf="@+id/tvGameDate" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvGameName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_20sdp"
                    android:ellipsize="end"
                    android:fontFamily="@font/inter_bold"
                    android:includeFontPadding="false"
                    android:maxLines="2"
                    android:text="@{bean.field.name}"
                    android:textColor="@color/black"
                    android:textSize="@dimen/_10ssp"
                    app:layout_constraintEnd_toEndOf="@+id/tvGameCity"
                    app:layout_constraintStart_toStartOf="@+id/tvGameCity"
                    app:layout_constraintTop_toBottomOf="@+id/tvGameCity" />


                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/clGameMode"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/_5sdp"
                    android:layout_marginTop="@dimen/_6sdp"
                    android:layout_marginBottom="@dimen/_5sdp"
                    android:background="@drawable/card_not_selected"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/clGamePlayer"
                    app:layout_constraintHorizontal_bias="0.5"
                    app:layout_constraintStart_toStartOf="@+id/tvGameCity"
                    app:layout_constraintTop_toBottomOf="@id/tvGameName">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/ivGameMode"
                        android:layout_width="@dimen/_22sdp"
                        android:layout_height="@dimen/_22sdp"
                        android:layout_marginTop="@dimen/_6sdp"
                        android:gravity="center"
                        android:padding="@dimen/_2sdp"
                        android:src="@drawable/basket_ball_fill"
                        app:layout_constraintEnd_toEndOf="@id/tvGameMode"
                        app:layout_constraintHorizontal_bias="0.5"
                        app:layout_constraintStart_toStartOf="@id/tvGameMode"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/games_dark_color" />


                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvGameMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="@dimen/_5sdp"
                        android:layout_marginTop="@dimen/_6sdp"
                        android:fontFamily="@font/inter_bold"
                        android:gravity="center"
                        android:paddingBottom="@dimen/_8sdp"
                        android:text="Done"
                        android:textColor="@color/black"
                        android:textSize="@dimen/_8ssp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/ivGameMode"
                        app:modeFormat="@{bean.mode}" />


                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/clGamePlayer"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginHorizontal="@dimen/_5sdp"
                    android:background="@drawable/card_not_selected"
                    app:layout_constraintBottom_toBottomOf="@+id/clGameMode"
                    app:layout_constraintEnd_toStartOf="@+id/clGameStatus"
                    app:layout_constraintStart_toEndOf="@+id/clGameMode"
                    app:layout_constraintTop_toTopOf="@id/clGameMode">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/ivGameOrganizer"
                        android:layout_width="@dimen/_22sdp"
                        android:layout_height="@dimen/_22sdp"
                        android:layout_marginTop="@dimen/_6sdp"
                        android:gravity="center"
                        android:src="@drawable/ic_round_person_40"
                        app:layout_constraintEnd_toEndOf="@id/tvGamePlayers"
                        app:layout_constraintHorizontal_bias="0.5"
                        app:layout_constraintStart_toStartOf="@id/tvGamePlayers"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/games_dark_color" />


                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvGamePlayers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="@dimen/_5sdp"
                        android:layout_marginTop="@dimen/_6sdp"
                        android:fontFamily="@font/inter_bold"
                        android:gravity="center"
                        android:paddingBottom="@dimen/_8sdp"
                        android:text='@{String.valueOf(bean.totalJoinedPlayers) + "\nplayers"}'
                        android:textColor="@color/black"
                        android:textSize="@dimen/_8ssp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/ivGameOrganizer" />


                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/clGameStatus"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginHorizontal="@dimen/_5sdp"
                    android:background="@drawable/card_not_selected"
                    app:layout_constraintBottom_toBottomOf="@+id/clGameMode"
                    app:layout_constraintEnd_toEndOf="@+id/tvGameCity"
                    app:layout_constraintStart_toEndOf="@+id/clGamePlayer"
                    app:layout_constraintTop_toTopOf="@id/clGameMode">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/ivGameStatus"
                        android:layout_width="@dimen/_20sdp"
                        android:layout_height="@dimen/_20sdp"
                        android:layout_marginTop="@dimen/_6sdp"
                        android:gravity="center"
                        android:padding="@dimen/_2sdp"
                        android:src="@drawable/round_call_received_24"
                        app:layout_constraintEnd_toEndOf="@id/tvGameStatus"
                        app:layout_constraintHorizontal_bias="0.5"
                        app:layout_constraintStart_toStartOf="@id/tvGameStatus"
                        app:layout_constraintTop_toTopOf="parent" />


                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvGameStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="@dimen/_5sdp"
                        android:layout_marginTop="@dimen/_6sdp"
                        android:fontFamily="@font/inter_bold"
                        android:gravity="center"
                        android:paddingBottom="@dimen/_8sdp"
                        app:gameStatus="@{bean}"
                        app:statusIconView="@{ivGameStatus}"
                        android:textColor="@color/black"
                        android:textSize="@dimen/_8ssp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/ivGameStatus" />


                </androidx.constraintlayout.widget.ConstraintLayout>


            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <androidx.appcompat.widget.AppCompatTextView
            android:layout_width="match_parent"
            android:layout_height="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/clMain" />


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>