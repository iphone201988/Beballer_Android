<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="bean"
            type="com.beballer.beballer.data.model.ProfileDataUser" />

        <variable
            name="vm"
            type="com.beballer.beballer.ui.organizers.dash_board.edit_organizer_profile.EditOrganizerVm" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.organizers.dash_board.edit_organizer_profile.EditOrganizerProfileFragment">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/consMain"
        android:layout_width="match_parent"
        android:layout_height="match_parent">




        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvBack"
            style="@style/TextView.InterMedium"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_8sdp"
            android:gravity="center"
            android:onClick="@{v->vm.onClick(v)}"
            android:padding="@dimen/_4sdp"
            android:text="Back"
            android:textColor="@color/black_000000"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvEditProfile"
            style="@style/TextView.InterMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingHorizontal="@dimen/_15sdp"
            android:text="Edit Profile"
            app:layout_constraintBottom_toBottomOf="@+id/tvBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tvBack" />


        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvSave"
            style="@style/TextView.InterMedium"
            android:layout_width="wrap_content"
            android:layout_marginEnd="@dimen/_8sdp"
            android:gravity="center"
            android:onClick="@{v->vm.onClick(v)}"
            android:padding="@dimen/_4sdp"
            android:text="Save"
            android:textColor="@color/black_000000"
            app:layout_constraintBottom_toBottomOf="@+id/tvBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tvBack" />


        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivProfileImage"
            setImageFromUrl="@{bean.profilePicture}"
            android:layout_width="@dimen/_50sdp"
            android:layout_height="@dimen/_50sdp"
            android:layout_marginTop="@dimen/_12sdp"
            android:contentDescription="@string/done"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_round_account_circle_40"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvEditProfile"
            app:shapeAppearance="@style/ShapeAppearanceOverlay.App.CornerSize50Percent" />


        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvChangePhoto"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/_10sdp"
            android:layout_marginStart="@dimen/_4sdp"
            android:background="@drawable/radius_20_bg"
            android:fontFamily="@font/inter_regular"
            android:gravity="start"
            android:onClick="@{v->vm.onClick(v)}"
            android:paddingHorizontal="@dimen/_5sdp"
            android:paddingTop="2dp"
            android:text="Edit profile"
            android:textColor="@color/white"
            android:textSize="@dimen/_5ssp"
            app:layout_constraintBottom_toBottomOf="@id/ivProfileImage"
            app:layout_constraintEnd_toEndOf="@+id/ivProfileImage"
            app:layout_constraintStart_toStartOf="@+id/ivProfileImage" />


        <View
            android:id="@+id/view"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="@dimen/_16sdp"
            android:background="@color/view_color"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvChangePhoto" />



        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvUserName"
            style="@style/TextView.InterMedium"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="@dimen/_10sdp"
            android:text="Username"
            android:textColor="@color/black_000000"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/view" />



        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/etUserName"
            style="@style/EditText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/_2sdp"
            android:backgroundTint="@color/transparent"
            android:ellipsize="end"
            android:gravity="center|end"
            android:hint="Enter user name"
            android:imeOptions="actionNext"
            android:inputType="textPersonName"
            android:nextFocusForward="@id/etCity"
            android:paddingEnd="@dimen/_12sdp"
            android:singleLine="true"
            android:text="@{bean.username}"
            android:textColor="@color/black_000000"
            android:textColorHint="@color/beballer_grey"
            app:layout_constraintBottom_toBottomOf="@+id/tvUserName"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tvUserName"
            app:layout_constraintTop_toTopOf="@+id/tvUserName" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/view_color"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvUserName" />


        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvCountry"
            style="@style/TextView.InterMedium"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="@dimen/_10sdp"
            android:text="Country"
            android:textColor="@color/black_000000"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvUserName" />


        <com.hbb20.CountryCodePicker
            android:id="@+id/countryCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_5sdp"
            android:layout_marginEnd="-35dp"
            android:paddingEnd="@dimen/_12sdp"
            app:ccpDialog_showCloseIcon="false"
            app:ccp_autoDetectCountry="false"
            app:ccp_contentColor="@color/dark_A9A9A9"
            app:ccp_defaultNameCode="Ro"
            app:ccp_showArrow="false"
            app:ccp_showFlag="true"
            app:ccp_showFullName="false"
            app:ccp_showNameCode="false"
            app:ccp_showPhoneCode="false"
            app:ccp_textSize="@dimen/_22ssp"
            app:layout_constraintBottom_toBottomOf="@+id/tvCountry"
            app:layout_constraintEnd_toStartOf="@+id/etCountryName"
            app:layout_constraintTop_toTopOf="@+id/tvCountry"/>



        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/etCountryName"
            style="@style/EditText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/_2sdp"
            android:backgroundTint="@color/transparent"
            android:ellipsize="end"
            android:focusable="false"
            android:gravity="center|end"
            android:hint="-"
            android:imeOptions="actionNext"
            android:inputType="textPersonName"
            android:nextFocusForward="@id/btnNext"
            android:paddingEnd="@dimen/_12sdp"
            android:singleLine="true"
            android:text="@{bean.country}"
            android:textColor="@color/black_000000"
            android:textColorHint="@color/beballer_grey"
            app:layout_constraintBottom_toBottomOf="@+id/countryCode"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/countryCode" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/view_color"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvCountry" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvRecruiters"
            style="@style/TextView.InterMedium"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="@dimen/_10sdp"
            android:text="Recruiters view"
            android:textColor="@color/black_000000"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvCountry" />


        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/etRecruiters"
            style="@style/EditText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/_2sdp"
            android:backgroundTint="@color/transparent"
            android:ellipsize="end"
            android:gravity="center|end"
            android:hint="Enter recruiters"
            android:imeOptions="actionNext"
            android:inputType="textPersonName"
            android:nextFocusForward="@id/btnNext"
            android:paddingEnd="@dimen/_12sdp"
            android:singleLine="true"
            android:text="@{bean.recutersViewed}"
            android:textColor="@color/black_000000"
            android:textColorHint="@color/beballer_grey"
            app:layout_constraintBottom_toBottomOf="@+id/tvRecruiters"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tvRecruiters"
            app:layout_constraintTop_toTopOf="@+id/tvRecruiters" />

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/tvDescription"
            style="@style/TextView.InterMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/_60sdp"
            android:layout_marginHorizontal="@dimen/_5sdp"
            android:layout_marginTop="@dimen/_10sdp"
            android:padding="@dimen/_5sdp"
            android:gravity="start"
            android:text="@{bean.profileDescription                                                 }"
            android:background="@drawable/edit_text_bg_with_radius_10"
            app:layout_constraintTop_toBottomOf="@id/tvRecruiters"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>


        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/btnDeleteAccount"
            style="@style/GreenButton"
            android:layout_width="0dp"
            android:layout_height="@dimen/_35sdp"
            android:layout_marginTop="@dimen/_40sdp"
            android:layout_marginBottom="@dimen/_20sdp"
            android:background="@drawable/card_not_selected"
            android:backgroundTint="@color/red_F27070"
            android:onClick="@{v->vm.onClick(v)}"
            android:paddingHorizontal="@dimen/_16sdp"
            android:text="Delete Account"
            android:layout_marginHorizontal="@dimen/_10sdp"
            android:textSize="@dimen/_12ssp"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />


    </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>